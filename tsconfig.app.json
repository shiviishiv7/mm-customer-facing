{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [],
    "skipLibCheck": true,
    "baseUrl": "src",
    "paths": {
      "@core/*": ["app/core/*"],
      "@environments/*": ["environments/*"],
      "@shared/*": ["app/shared/*"]
    }
  },
  "files": [
    "src/main.ts"
  ],
  "include": [
    "src/**/*.d.ts"
  ]
}
