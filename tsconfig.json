{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@core/*": ["app/core/*"],
      "@environments/*": ["environments/*"],
      "@shared/*": ["app/shared/*"]
    },
    "experimentalDecorators": true, // donot remove these flag are used for object conversion from plan to class and class to plain
    "emitDecoratorMetadata": true,// donot remove these flag are used for object conversion from plan to class and class to plain
    "outDir": "./dist/out-tsc",
    "strict": false,
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,

    "moduleResolution": "node",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": [
      "ES2022",
      "dom"
    ],
    "forceConsistentCasingInFileNames": false,
    "strictNullChecks": false,
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": false,
    "strictInputAccessModifiers": false,
    "strictTemplates": false
  },
  "files": [
    "src/main.ts",
  ]
}
